{
  "release-type": "go",
  "include-component-in-tag": true,
  "tag-separator": "/",
  "plugins": [
    "sentence-case"
  ],
  "packages": {
    "agentplatform": {
      "component": "agentplatform"
    },
    "auth": {
      "component": "auth",
      "exclude-paths": [
        "auth/oauth2adapt"
      ]
    },
    "auth/oauth2adapt": {
      "component": "auth/oauth2adapt"
    },
    "bigquery": {
      "component": "bigquery",
      "exclude-paths": [
        "bigquery/v2"
      ]
    },
    "bigquery/v2": {
      "component": "bigquery/v2"
    },
    "bigtable": {
      "component": "bigtable"
    },
    "civil": {
      "component": "root-module"
    },
    "compute/metadata": {
      "component": "compute/metadata"
    },
    "datastore": {
      "component": "datastore",
      "extra-files": [
        {
          "jsonpath": "$.clientLibrary.version",
          "path": "/internal/generated/snippets/datastore/admin/apiv1/snippet_metadata.google.datastore.admin.v1.json",
          "type": "json"
        }
      ]
    },
    "firestore": {
      "component": "firestore"
    },
    "pubsub": {
      "component": "pubsub",
      "exclude-paths": [
        "pubsub/v2"
      ]
    },
    "pubsub/v2": {
      "component": "pubsub/v2"
    },
    "pubsublite": {
      "component": "pubsublite"
    },
    "spanner": {
      "component": "spanner"
    },
    "storage": {
      "component": "storage"
    },
    "vertexai": {
      "component": "vertexai"
    }
  }
}