{
  "include-component-in-tag": true,
  "packages": {
    "pubsub": {
      "component": "pubsub",
      "exclude-paths": [
        "pubsub/v2"
      ]
    },
    "pubsub/v2": {
      "component": "pubsub/v2"
    }
  },
  "plugins": [
    "sentence-case"
  ],
  "release-type": "go-librarian",
  "separate-pull-requests": true,
  "tag-separator": "/"
}
